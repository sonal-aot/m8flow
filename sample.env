# Copy to .env (see README).
# Backend accepts both M8FLOW_BACKEND_* and SPIFFWORKFLOW_BACKEND_* for mapped vars (see extensions/env_var_mapper.py).
#
# --- Postgres (required for m8flow-db; set POSTGRES_PASSWORD). ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Host port published by docker/m8flow-docker-compose.yml (m8flow-db).
POSTGRES_HOST_PORT=6843

# --- Flask / Backend ---
FLASK_DEBUG=1
FLASK_ENV=development
FLASK_APP=app.py
# Use a random secret (32+ chars).
FLASK_SESSION_SECRET_KEY=123456789abcdef0123456789abcdef

M8FLOW_BACKEND_ENV=local_development
M8FLOW_BACKEND_LOG_LEVEL=INFO
WATCHFILES_FORCE_POLLING=true

# --- Database (SQLAlchemy URI) ---
M8FLOW_BACKEND_DATABASE_TYPE=postgres
M8FLOW_BACKEND_DATABASE_URI=postgresql://postgres:postgres@localhost:6843/postgres
# M8FLOW and Spiff DB migrations on startup.
M8FLOW_BACKEND_UPGRADE_DB=true
M8FLOW_BACKEND_SW_UPGRADE_DB=true


KEYCLOAK_PROXY_PORT=6842
KEYCLOAK_MGMT_PORT=6849
REDIS_HOST_PORT=6848
MINIO_API_PORT=6846
MINIO_CONSOLE_PORT=6847
M8FLOW_NATS_PORT=6845
M8FLOW_NATS_MONITORING_PORT=6851
M8FLOW_NATS_UI_PORT=6852
# Standalone MinIO local-dev compose (docker/minio.local-dev.docker-compose.yml).
MINIO_LOCAL_DEV_API_PORT=16846
MINIO_LOCAL_DEV_CONSOLE_PORT=16847
M8FLOW_FRONTEND_PORT=6841
M8FLOW_BACKEND_PORT=6840
M8FLOW_BACKEND_URL=http://localhost:6840
M8FLOW_BACKEND_URL_FOR_FRONTEND=http://localhost:6841
SPIFFWORKFLOW_BACKEND_API_PATH_PREFIX=/v1.0
# CORS: comma-separated frontend origins (host:port).
M8FLOW_BACKEND_CORS_ALLOW_ORIGINS=localhost:6841,localhost:5173,127.0.0.1:6841,localhost:6841

# Behind a TLS-terminating proxy/ALB, set proxy-fix count so forwarded headers are trusted
# (ensures HTTPS redirect_uri for Keycloak). Must match chain length (typical ALB: 1).
# M8FLOW_BACKEND_PROXY_COUNT_FOR_PROXY_FIX=1

# BPMN and templates paths (container or host).
M8FLOW_BACKEND_BPMN_SPEC_ABSOLUTE_DIR=./data/process_models
M8FLOW_TEMPLATES_STORAGE_DIR=./data/templates
# Load sample templates into DB on startup (one-time; skips duplicates).
M8FLOW_LOAD_SAMPLE_TEMPLATES=true

# --- Auth (OIDC / Keycloak) ---
# KEYCLOAK_HOSTNAME=http://localhost:6842
# KEYCLOAK_HOSTNAME_URL=http://localhost:6842
# See docs: README Keycloak Setup (hostname/issuer notes).
M8FLOW_KEYCLOAK_URL=http://localhost:6842
M8FLOW_BACKEND_OPEN_ID_SERVER_URL=http://localhost:6842/realms/m8flow
M8FLOW_BACKEND_OPEN_ID_CLIENT_ID=m8flow-backend
M8FLOW_BACKEND_OPEN_ID_CLIENT_SECRET_KEY=
M8FLOW_BACKEND_OPEN_ID_IS_AUTHORITY_FOR_USER_GROUPS=true
KEYCLOAK_ENABLE_CLIENT_AUTH=false
# Tenant JWT / tenant login: PKCS#12 keystore (optional).
M8FLOW_KEYCLOAK_SPOKE_CLIENT_ID=m8flow-backend
M8FLOW_KEYCLOAK_SPOKE_KEYSTORE_P12=extensions/m8flow-backend/keystore.p12
# Keystore password; required for tenant login flow when using spoke keystore.
M8FLOW_KEYCLOAK_SPOKE_KEYSTORE_PASSWORD=

# Optional Keycloak auth configs (identifier should match frontend cookie).
# Advanced master/admin-cli config notes: extensions/m8flow-backend/keycloak/KEYCLOAK_SETUP.md
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__0__identifier=m8flow
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__0__label=M8Flow Realm
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__0__uri=http://localhost:6842/realms/m8flow
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__0__client_id=m8flow-backend
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__0__client_secret=JXeQExm0JhQPLumgHtIIqf52bDalHz0q
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__1__identifier=master
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__1__label=Master
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__1__uri=http://localhost:6842/realms/master
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__1__client_id=m8flow-backend
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__1__client_secret=JXeQExm0JhQPLumgHtIIqf52bDalHz0q
SPIFFWORKFLOW_BACKEND_AUTH_CONFIGS__1__additional_valid_client_ids=admin-cli
SPIFFWORKFLOW_BACKEND_OPEN_ID_ADDITIONAL_VALID_ISSUERS=http://localhost:6842/realms/master,http://localhost:6842/realms/m8flow
# Optional local bootstrap for master realm browser client and global admin user.
# M8FLOW_KEYCLOAK_MASTER_CLIENT_SECRET=JXeQExm0JhQPLumgHtIIqf52bDalHz0q
# KEYCLOAK_SUPER_ADMIN_USER=super-admin
# KEYCLOAK_SUPER_ADMIN_PASSWORD=super-admin
# Keep master and shared realm token/session lifetimes aligned.
# M8FLOW_KEYCLOAK_ACCESS_TOKEN_LIFESPAN=1800
# M8FLOW_KEYCLOAK_ACCESS_TOKEN_LIFESPAN_FOR_IMPLICIT_FLOW=900
# M8FLOW_KEYCLOAK_SSO_SESSION_IDLE_TIMEOUT=86400
# M8FLOW_KEYCLOAK_SSO_SESSION_MAX_LIFESPAN=864000
# M8FLOW_KEYCLOAK_CLIENT_SESSION_IDLE_TIMEOUT=0
# M8FLOW_KEYCLOAK_CLIENT_SESSION_MAX_LIFESPAN=0
# M8FLOW_KEYCLOAK_REVOKE_REFRESH_TOKEN=false

# --- Celery / Redis ---
M8FLOW_BACKEND_CELERY_ENABLED=true
# In Docker Compose, use the redis service name and container port 6379 (not REDIS_HOST_PORT, which maps host→container).
M8FLOW_BACKEND_CELERY_BROKER_URL=redis://redis:6379/0
M8FLOW_BACKEND_CELERY_RESULT_BACKEND=redis://redis:6379/0
# Keep false for backend/API; worker and flower launchers override.
# M8FLOW_BACKEND_RUNNING_IN_CELERY_WORKER=false
M8FLOW_BACKEND_RUN_BACKGROUND_SCHEDULER_IN_CREATE_APP=true
M8FLOW_BACKEND_CELERY_ENABLE_EVENTS=true
M8FLOW_BACKEND_CELERY_FLOWER_PORT=6850
M8FLOW_BACKEND_CELERY_AUTOSCALE_MIN=2
M8FLOW_BACKEND_CELERY_AUTOSCALE_MAX=4
# optional
# M8FLOW_BACKEND_CELERY_POOL=prefork
# M8FLOW_BACKEND_CELERY_CONCURRENCY=2

# ---Flower ---
# Optional Flower basic auth: user:password (empty disables).
M8FLOW_BACKEND_CELERY_FLOWER_BASIC_AUTH=admin:admin
# Docker bind-mounts ../process_models into backend and Celery containers by default.


# --- Connector proxy ---
CONNECTOR_PROXY_PORT=6844
M8FLOW_BACKEND_CONNECTOR_PROXY_URL=http://localhost:6844
# --- M8Flow Connector: SMTP ---
# SMTP attachment source dir (host path).
M8FLOW_CONNECTOR_SMTP_ATTACHMENTS_DIR=./data/email_attachments
# SMTP attachment user-visible mount path in service tasks.
M8FLOW_CONNECTOR_SMTP_ATTACHMENTS_USER_ACCESS_DIR=./data/email_attachments
M8FLOW_CONNECTOR_SMTP_ATTACHMENTS_LIMIT_IN_MB=10
M8FLOW_CONNECTOR_SMTP_TIMEOUT_SECONDS=300

# --- M8Flow Connector: Slack ---
# Slack attachment source dir (host path).
M8FLOW_CONNECTOR_SLACK_ATTACHMENTS_DIR=./data/slack_attachments
# Slack attachment user-visible mount path in service tasks.
M8FLOW_CONNECTOR_SLACK_ATTACHMENTS_USER_ACCESS_DIR=./data/slack_attachments
M8FLOW_CONNECTOR_SLACK_UPLOAD_FILE_LIMIT_MB=50
# --- Permissions ---
M8FLOW_BACKEND_PERMISSIONS_FILE_ABSOLUTE_PATH=./m8flow-backend/src/m8flow_backend/config/permissions/m8flow.yml
#M8FLOW_BACKEND_PERMISSIONS_FILE_NAME=m8flow.yml

# Multitenant mode: true enables tenant selection routes.
MULTI_TENANT_ON=true

# --- SQLAlchemy Logs ---
M8FLOW_SQLALCHEMY_ECHO=false

# --- Encryption (sensitive data at rest) ---
M8FLOW_BACKEND_ENCRYPTION_LIB=cryptography
M8FLOW_BACKEND_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# --- Tenancy ---
# JWT claim name for tenant id.
# M8FLOW_TENANT_CLAIM=m8flow_tenant_id

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
# Keycloak admin app settings.
# See docs: README Keycloak Setup and docs/env-reference.md.
KEYCLOAK_HOSTNAME=http://localhost:6842
# Optional public app URL when app and Keycloak are on different hosts.
# M8FLOW_APP_PUBLIC_BASE_URL=
KEYCLOAK_URL=http://localhost:6842
# Single-tenant mode uses the shared m8flow realm. Tenant realms are created later via API when needed.
KEYCLOAK_REALM=m8flow
KEYCLOAK_ADMIN_USER=admin
# Admin password for create-realm API.
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_ID=my-backend-app
KEYCLOAK_CLIENT_SECRET=
# Optional mTLS cert/key paths.
# KEYCLOAK_CERT_FILE=
# KEYCLOAK_KEY_FILE=
# Keycloak DB (used by docker/m8flow-docker-compose.yml for keycloak-db and keycloak service)
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
KC_HTTP_PORT=8080
KC_HOSTNAME_STRICT=false


# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Diagnostics ---
M8FLOW_STARTUP_DIAGNOSTICS=false

# --- NATS / Event Driven Architecture ---
M8FLOW_NATS_ENABLED=false
M8FLOW_NATS_URL=nats://admin:admin@localhost:6845
M8FLOW_NATS_STREAM_NAME=M8FLOW_EVENTS
M8FLOW_NATS_SUBJECT=m8flow.events.>
M8FLOW_NATS_DURABLE_NAME=m8flow-engine-consumer
M8FLOW_NATS_FETCH_BATCH=10
M8FLOW_NATS_FETCH_TIMEOUT=2.0
M8FLOW_NATS_DEDUP_BUCKET=m8flow-dedup
M8FLOW_NATS_DEDUP_TTL=86400
# NATS Token Salt
M8FLOW_NATS_TOKEN_SALT=changeme_nats_salt
# NATS Core Authentication (used by nats server --user/--pass and all services connecting to it)
M8FLOW_NATS_USER=admin
M8FLOW_NATS_PASSWORD=admin
# Notification events (M8F-339) — separate stream so the engine consumer never sees them
M8FLOW_NATS_NOTIFICATIONS_STREAM_NAME=M8FLOW_NOTIFICATIONS
M8FLOW_NATS_NOTIFICATIONS_SUBJECT=m8flow.notifications.>
M8FLOW_NATS_NOTIFICATIONS_DURABLE_NAME=m8flow-notification-worker

# --- External Forms ---
# Secure-link validity in seconds (7 days)
M8FLOW_EXTERNAL_FORM_LINK_TTL_SECONDS=604800

# --- External Form Notifications (M8F-339) ---
M8FLOW_NOTIFICATION_SWEEP_INTERVAL_SECONDS=60
M8FLOW_NOTIFICATION_SWEEP_GRACE_SECONDS=120
M8FLOW_NOTIFICATION_MAX_ATTEMPTS=5
# SMTP is NOT a global env var. Each tenant configures its own SMTP via encrypted
# tenant secrets: SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD, SMTP_FROM_EMAIL,
# SMTP_STARTTLS, SMTP_SSL (host + SMTP_FROM_EMAIL required). For local testing, point a
# tenant's SMTP_HOST/SMTP_PORT at the mailpit dev service below (mailpit:1025 in-compose).
M8FLOW_MAILPIT_UI_PORT=6853
M8FLOW_MAILPIT_SMTP_PORT=6854
